# syntax=docker/dockerfile:1.24@sha256:87999aa3d42bdc6bea60565083ee17e86d1f3339802f543c0d03998580f9cb89
FROM maven:3.9.16-eclipse-temurin-17 AS maven-bin

FROM ghcr.io/graalvm/native-image-community:25 AS native-builder

WORKDIR /workspace

COPY --from=maven-bin /usr/share/maven /usr/share/maven
COPY --from=maven-bin /usr/bin/mvn /usr/bin/mvn

ENV MAVEN_HOME=/usr/share/maven
ENV PATH="${MAVEN_HOME}/bin:${PATH}"

COPY pom.xml /workspace/pom.xml
COPY src /workspace/src

RUN --mount=type=cache,target=/root/.m2 mvn -Pnative -DskipTests package

# Bundle zlib runtime needed by the native executable.
RUN set -eux; \
	zlib_path="$(ldd /workspace/target/proxera | sed -n 's/.*=> \(\/[^ ]*libz\.so\.1[^ ]*\).*/\1/p; s/^\(\/[^ ]*libz\.so\.1[^ ]*\).*/\1/p' | head -n 1)"; \
	[ -n "$zlib_path" ]; \
	cp -v "$(readlink -f "$zlib_path")" /workspace/target/libz.so.1

# Prepare writable app data directory for non-root runtime user.
RUN mkdir -p /workspace/runtime-data && touch /workspace/runtime-data/.keep

# Alpine is not used here because the default native binary is glibc-linked.
# Distroless base includes additional runtime libraries (for example zlib)
# while remaining small and production-oriented.
FROM gcr.io/distroless/base-debian12:nonroot

WORKDIR /app

# Copy the executable and all sidecar native libraries emitted by native-image.
# This is resilient to future GraalVM outputs (additional .so files).
COPY --from=native-builder --chown=65532:65532 /workspace/target/ /app/

# Ensure embedded database path is writable for UID 65532 (nonroot).
COPY --from=native-builder --chown=65532:65532 /workspace/runtime-data/ /app/data/

# Ensure the dynamic loader can resolve bundled Graal sidecar libraries in /app.
ENV LD_LIBRARY_PATH=/app

EXPOSE 8080

ENTRYPOINT ["/app/proxera"]
